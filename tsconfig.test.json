{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": ["node", "vite/client", "vitest/globals"],
    "noEmit": true,
    "paths": {"@/*": ["./src/*"]}
  },
  "include": [
    "src/env.d.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "shared/**/*.ts"
  ]
}
