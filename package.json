{
  "name": "minichat-github-pages",
  "private": true,
  "version": "2.7.0",
  "type": "module",
  "engines": {
    "node": "22.16.x",
    "npm": "10.9.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "check:brand": "node scripts/check-brand-assets.mjs",
    "check:css-integrity": "node scripts/check-css-integrity.mjs",
    "check:typography": "node scripts/check-typography-policy.mjs",
    "check:public-copy": "node scripts/check-public-copy.mjs",
    "check": "npm run check:documents && npm run check:registry && npm run check:toolchain && npm run check:vite-policy && npm run lint && npm run check:public-variables && npm run check:workflow-security && npm run check:inline-styles && npm run build && npm run check:vite && npm run check:comments && npm run check:brand && npm run check:css-integrity && npm run check:typography && npm run typecheck:tests && npm run test && npm run check:public-copy && npm run check:built-security",
    "check:comments": "node scripts/check-comment-policy.mjs",
    "check:public-variables": "node scripts/check-public-variables.mjs",
    "check:built-security": "node scripts/check-built-security.mjs",
    "configure:variables": "node scripts/configure-github-variables.mjs",
    "check:inline-styles": "node scripts/check-inline-style-policy.mjs",
    "check:workflow-security": "node scripts/check-workflow-security.mjs",
    "check:registry": "node scripts/check-package-registry.mjs",
    "check:toolchain": "node scripts/check-toolchain-consistency.mjs",
    "check:vite-policy": "node scripts/check-vite-policy.mjs",
    "check:vite-output": "node scripts/check-vite-output.mjs",
    "check:vite-preview": "node scripts/check-vite-preview.mjs",
    "check:vite": "npm run check:vite-output && npm run check:vite-preview",
    "check:documents": "node scripts/check-document-policy.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
